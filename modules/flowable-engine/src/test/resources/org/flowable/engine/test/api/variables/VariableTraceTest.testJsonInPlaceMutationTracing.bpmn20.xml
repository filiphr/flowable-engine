<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:flowable="http://flowable.org/bpmn"
  targetNamespace="http://www.flowable.org/processdef">

  <process id="jsonInPlaceMutationProcess" isExecutable="true">

    <startEvent id="theStart" />
    <sequenceFlow sourceRef="theStart" targetRef="serviceTask1" />

    <!-- First service task: adds a field to the JSON variable -->
    <serviceTask id="serviceTask1"
        flowable:class="org.flowable.engine.test.api.variables.VariableTraceTest$AddFieldToJsonDelegate" />
    <sequenceFlow sourceRef="serviceTask1" targetRef="serviceTask2" />

    <!-- Second service task: modifies an existing field in the JSON variable -->
    <serviceTask id="serviceTask2"
        flowable:class="org.flowable.engine.test.api.variables.VariableTraceTest$ModifyJsonFieldDelegate" />
    <sequenceFlow sourceRef="serviceTask2" targetRef="theEnd" />

    <endEvent id="theEnd" />

  </process>

</definitions>
