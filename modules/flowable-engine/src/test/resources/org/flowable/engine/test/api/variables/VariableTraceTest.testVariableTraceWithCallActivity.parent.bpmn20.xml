<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:flowable="http://flowable.org/bpmn"
  targetNamespace="http://www.flowable.org/processdef">

  <process id="variableTraceCallActivityParent" isExecutable="true">

    <startEvent id="parentStart" />
    <sequenceFlow sourceRef="parentStart" targetRef="callActivity1" />

    <callActivity id="callActivity1" calledElement="variableTraceCallActivityChild">
      <extensionElements>
        <flowable:in source="inputVar" target="childInput" />
        <flowable:out source="childOutput" target="outputVar" />
      </extensionElements>
    </callActivity>
    <sequenceFlow sourceRef="callActivity1" targetRef="parentUserTask" />

    <userTask id="parentUserTask" name="Parent User Task" />
    <sequenceFlow sourceRef="parentUserTask" targetRef="parentEnd" />

    <endEvent id="parentEnd" />

  </process>

</definitions>
