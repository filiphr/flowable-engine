<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:flowable="http://flowable.org/bpmn"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
  targetNamespace="http://www.flowable.org/processdef">

  <process id="creditCheck" name="Credit Check" isExecutable="true">

    <startEvent id="theStart" />
    <sequenceFlow id="flow1" sourceRef="theStart" targetRef="calculateScore" />

    <serviceTask id="calculateScore" name="Calculate Credit Score"
        flowable:class="org.flowable.engine.test.api.variables.VariableTraceDataGenerator$CalculateCreditScoreDelegate" />
    <sequenceFlow id="flow2" sourceRef="calculateScore" targetRef="assessRisk" />

    <serviceTask id="assessRisk" name="Assess Risk"
        flowable:class="org.flowable.engine.test.api.variables.VariableTraceDataGenerator$AssessRiskDelegate" />
    <sequenceFlow id="flow3" sourceRef="assessRisk" targetRef="theEnd" />

    <endEvent id="theEnd" />

  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_creditCheck">
    <bpmndi:BPMNPlane bpmnElement="creditCheck" id="BPMNPlane_creditCheck">
      <bpmndi:BPMNShape bpmnElement="theStart" id="BPMNShape_theStart">
        <omgdc:Bounds height="30.0" width="30.0" x="100.0" y="163.0" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="calculateScore" id="BPMNShape_calculateScore">
        <omgdc:Bounds height="80.0" width="100.0" x="180.0" y="138.0" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="assessRisk" id="BPMNShape_assessRisk">
        <omgdc:Bounds height="80.0" width="100.0" x="330.0" y="138.0" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="theEnd" id="BPMNShape_theEnd">
        <omgdc:Bounds height="28.0" width="28.0" x="480.0" y="164.0" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge bpmnElement="flow1" id="BPMNEdge_flow1">
        <omgdi:waypoint x="130.0" y="178.0" />
        <omgdi:waypoint x="180.0" y="178.0" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="flow2" id="BPMNEdge_flow2">
        <omgdi:waypoint x="280.0" y="178.0" />
        <omgdi:waypoint x="330.0" y="178.0" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="flow3" id="BPMNEdge_flow3">
        <omgdi:waypoint x="430.0" y="178.0" />
        <omgdi:waypoint x="480.0" y="178.0" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>
